# PitchPulse Backend Environment Variables
# Copy this to .env and fill in the values

# Database (Docker Compose default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pitchpulse

# Firebase
FIREBASE_PROJECT_ID=pitchpulse-demo
# FIREBASE_KEY_PATH=/path/to/serviceAccountKey.json

# Football Data Provider
PROVIDER_API_KEY=demo-key
USE_DEMO_DATA=True

# Gemini AI (Required for real AI features; omit for mock fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# Actian VectorAI DB (omit for local fallback)
# VECTOR_DB_URL=
# VECTOR_DB_TOKEN=

# Vultr S3 (optional, for movement videos)
# VULTR_S3_ENDPOINT=
# VULTR_S3_ACCESS_KEY=
# VULTR_S3_SECRET_KEY=
# VULTR_S3_BUCKET=
